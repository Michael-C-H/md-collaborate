# ────────────────────────────────────────────────────────────
# md-collab 环境变量样例（生产部署用，复制为 .env 后填值）
# ────────────────────────────────────────────────────────────

# ── 应用基础 ────────────────────────────────────────────────
NODE_ENV=production
# nginx 容器对外端口；80 已被占可改 8080 等，对应 http://host:8080
HTTP_PORT=10086

# ────────────────────────────────────────────────────────────
# 部署形态（关键开关）
# ────────────────────────────────────────────────────────────
# 留空：默认形态，连接外部 MySQL / Redis
# 写成 mysql,redis：一体化部署，compose 启 mysql + redis 容器【可按需】
COMPOSE_PROFILES="mysql,redis"

# ────────────────────────────────────────────────────────────
# 数据库连接（必填）
# ────────────────────────────────────────────────────────────
# 外部 MySQL：DATABASE_URL=mysql://<user>:<pwd>@<host>:3306/<db>
#   例如：mysql://mdcollab:S3cret@10.0.0.5:3306/md_collab
# 一体化（COMPOSE_PROFILES="mysql,redis"）：host 必须写成服务名 mysql，
#   user/pwd/db 必须与下面 MYSQL_USER / MYSQL_PASSWORD / MYSQL_DATABASE 一致
DATABASE_URL=mysql://mdcollab:please-change-me@mysql:3306/md_collab

# ── Redis（必填）───────────────────────────────────────────
# 外部 Redis：填实际主机名 / IP
# 一体化部署：填服务名 redis
REDIS_HOST=redis
REDIS_PORT=6379
# 空字符串表示无密码
REDIS_PASSWORD=

# ────────────────────────────────────────────────────────────
# ⚠️ 以下三项仅 COMPOSE_PROFILES=bundled-db 时用到（初始化 MySQL 容器）
# 用外部 MySQL 时可保留也可删
# ────────────────────────────────────────────────────────────
MYSQL_USER=mdcollab
MYSQL_PASSWORD=please-change-me
MYSQL_DATABASE=md_collab

# ── Session（iron-session 加密密钥）─────────────────────────
# 必须 >=32 字符随机串；生成命令：openssl rand -hex 32
SESSION_PASSWORD=please-replace-with-a-long-random-string-of-32-plus-chars
SESSION_COOKIE_NAME=md_collab_session
# HTTP 部署务必 false；上 HTTPS 后改为 true（否则浏览器不会保存 / 发送 cookie）
SESSION_COOKIE_SECURE=false

# ── SSO（由三方系统提供）────────────────────────────────────
SSO_BASE_URL=http://sso.example.local
SSO_CLIENT_ID=prod-client
SSO_CLIENT_SECRET=please-replace-with-real-secret
# 登出后跳转的三方首页
SSO_LOGOUT_REDIRECT=http://sso.example.local/

# ── 上传与边界 ─────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=10
MAX_IMPORT_MD_SIZE_MB=5
MAX_IMPORT_ZIP_SIZE_MB=50

# ── 协同 ────────────────────────────────────────────────────
MAX_EDITORS_PER_DOC=10
TOTAL_CONCURRENCY_LIMIT=100

# ── 回收站清理（软删 N 天后物理删除）──────────────────────────
TRASH_RETENTION_DAYS=30

# ── 日志 ────────────────────────────────────────────────────
LOG_LEVEL=info
